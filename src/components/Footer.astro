---
/** Pied de page — logo, navigation, liens légaux, rappel infos + © Le Shelby. */
import Logo from './Logo.astro';
import { mainNav, legalNav } from '../data/nav';
import { site } from '../data/site';

const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="wrap footer-grid">
    <div class="footer-brand">
      <Logo width={52} height={28} stroke="#c9a85f" fill="none" glow={false} class="footer-mark" />
      <div class="footer-word">LE SHELBY</div>
      <p class="footer-tag">{site.tagline}</p>
      <p class="footer-line">
        {site.addressLine}<br />
        {site.hoursShort}
      </p>
    </div>

    <nav class="footer-nav" aria-label="Liens du pied de page">
      <div class="footer-col">
        <h2 class="footer-h">Naviguer</h2>
        <ul>
          {mainNav.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
      <div class="footer-col">
        <h2 class="footer-h">Le bar</h2>
        <ul>
          <li><a href={site.phoneHref}>{site.phoneDisplay}</a></li>
          <li><span class="footer-faint">{site.hours}</span></li>
          <li><span class="footer-faint">{site.closed}</span></li>
          {site.email && <li><a href={`mailto:${site.email}`}>{site.email}</a></li>}
        </ul>
      </div>
    </nav>
  </div>

  <div class="wrap footer-base">
    <div class="footer-legal">
      {legalNav.map((link, i) => (
        <>
          {i > 0 && <span class="footer-dot" aria-hidden="true">·</span>}
          <a href={link.href}>{link.label}</a>
        </>
      ))}
    </div>
    <div class="footer-copy">© {year} {site.name} · À consommer avec modération</div>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    z-index: 3;
    background: var(--bg-footer);
    border-top: 1px solid rgba(227, 181, 82, .2);
    padding: 44px 22px 30px;
  }
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 30px;
  }

  .footer-brand { text-align: center; }
  .footer-mark { margin: 0 auto 8px; opacity: .9; }
  .footer-word {
    font-family: var(--font-display);
    font-size: 16px;
    letter-spacing: .18em;
    color: var(--gold-warm);
  }
  .footer-tag {
    margin: 6px 0 0;
    font-family: var(--font-display);
    font-size: 9px;
    letter-spacing: .32em;
    color: var(--gold-soft);
  }
  .footer-line {
    margin: 14px 0 0;
    font-size: 16px;
    line-height: 1.5;
    color: var(--muted-4);
  }

  .footer-nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 22px;
  }
  .footer-h {
    margin: 0 0 12px;
    font-family: var(--font-display);
    font-size: 11px;
    letter-spacing: .18em;
    color: var(--gold-400);
  }
  .footer-nav ul { list-style: none; margin: 0; padding: 0; }
  .footer-nav li { margin: 0 0 9px; font-size: 16px; line-height: 1.3; }
  .footer-nav a { color: var(--cream-deep); text-decoration: none; }
  .footer-nav a:hover,
  .footer-nav a:focus-visible { color: var(--gold-200); text-decoration: underline; }
  .footer-faint { color: var(--muted-4); }

  .footer-base {
    margin-top: 34px;
    padding-top: 20px;
    border-top: 1px solid rgba(227, 181, 82, .12);
    text-align: center;
  }
  .footer-legal {
    display: flex;
    flex-wrap: wrap;
    gap: 6px 10px;
    justify-content: center;
    font-size: 15px;
  }
  .footer-legal a { color: var(--muted-3); text-decoration: none; }
  .footer-legal a:hover,
  .footer-legal a:focus-visible { color: var(--gold-soft); text-decoration: underline; }
  .footer-dot { color: var(--muted-4); }
  .footer-copy {
    margin-top: 12px;
    font-size: 14px;
    color: var(--muted-4);
  }

  /* tablette + : passe en 2 colonnes (marque | nav) */
  @media (min-width: 680px) {
    .footer-grid { grid-template-columns: 1.1fr 1fr; align-items: start; }
    .footer-brand { text-align: left; }
    .footer-mark { margin: 0 0 8px; }
  }
</style>
